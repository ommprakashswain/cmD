rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Updates: public read for auto-updating clients.
    // Writes are denied.
    match /updates/{updateId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
